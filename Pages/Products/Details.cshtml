@page
@model GESTION_PANIER.Pages.Products.DetailsModel
@using System.Globalization

@{
    ViewData["Title"] = "Détails du produit";
}

<h1>Détails du produit</h1>

@if (Model.Product == null)
{
    <div class="alert alert-warning">
        Produit non trouvé.
    </div>
}
else
{
    <div>
        <h4>Product</h4>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Product!.Name)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.Product!.Name)</dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Product!.Description)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Product!.Description)
            </dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Product!.Price)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.Product!.Price)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Product!.Quantity)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.Product!.Quantity)</dd>

            <dt class="col-sm-2">Catégorie</dt>
            <dd class="col-sm-10">@Model.Product!.Category?.Name </dd>

            <dt class="col-sm-2">Image</dt>
            <dd class="col-sm-10">
                <img src="@Model.Product!.ImagePath" style="max-height:150px; object-fit:cover;" alt="Image du produit" />
            </dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Product!.ReleaseDate)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.Product!.ReleaseDate)</dd>
        </dl>
    </div>

    <div>
        <a asp-page="./Edit" asp-route-id="@Model.Product!.Id" class="btn btn-warning">Modifier</a>
        <a asp-page="./Index" class="btn btn-secondary">Retour à la liste</a>
    </div>
}
